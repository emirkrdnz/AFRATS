{
  "JwtSettings": {
    "Secret": "",
    "Issuer": "afrats-auth",
    "Audience": "afrats-api"
  },

  "CorsSettings": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:5173"
    ]
  },

  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "AuthorizationPolicy": "anonymous",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        }
      },
      "txn-route": {
        "ClusterId": "txn-cluster",
        "AuthorizationPolicy": "anonymous",
        "Match": {
          "Path": "/api/transactions/{**catch-all}"
        }
      },
      "ml-health-route": {
        "ClusterId": "ml-cluster",
        "AuthorizationPolicy": "anonymous",
        "Match": {
          "Path": "/api/ml/health"
        }
      },
      "ml-route": {
        "ClusterId": "ml-cluster",
        "AuthorizationPolicy": "anonymous",
        "Match": {
          "Path": "/api/ml/{**catch-all}"
        }
      },
      "notif-route": {
        "ClusterId": "notif-cluster",
        "AuthorizationPolicy": "anonymous",
        "Match": {
          "Path": "/api/notifications/{**catch-all}"
        }
      },
      "health-auth-route": {
        "ClusterId": "auth-cluster",
        "AuthorizationPolicy": "anonymous",
        "Match": {
          "Path": "/health/auth"
        },
        "Transforms": [
          { "PathSet": "/health" }
        ]
      },
      "health-txn-route": {
        "ClusterId": "txn-cluster",
        "AuthorizationPolicy": "anonymous",
        "Match": {
          "Path": "/health/txn"
        },
        "Transforms": [
          { "PathSet": "/health" }
        ]
      },
      "health-ml-route": {
        "ClusterId": "ml-cluster",
        "AuthorizationPolicy": "anonymous",
        "Match": {
          "Path": "/health/ml"
        },
        "Transforms": [
          { "PathSet": "/health" }
        ]
      },
      "health-notif-route": {
        "ClusterId": "notif-cluster",
        "AuthorizationPolicy": "anonymous",
        "Match": {
          "Path": "/health/notif"
        },
        "Transforms": [
          { "PathSet": "/health" }
        ]
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "default": {
            "Address": "http://afrats-auth:8080"
          }
        }
      },
      "txn-cluster": {
        "Destinations": {
          "default": {
            "Address": "http://afrats-txn:8080"
          }
        }
      },
      "ml-cluster": {
        "Destinations": {
          "default": {
            "Address": "http://afrats-ml:8000"
          }
        }
      },
      "notif-cluster": {
        "Destinations": {
          "default": {
            "Address": "http://afrats-notif:8080"
          }
        }
      }
    }
  },

  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Yarp": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ]
  }
}
